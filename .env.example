# WeatherSniffer configuration — copy to .env, fill in, chmod 600 .env
# (.env is gitignored; a git pull never clobbers it.)

# --- Database (required) -----------------------------------------------------
# Postgres DSN for the SHARED database the app family uses.
DATABASE_URL=postgresql://weathersniffer:CHANGE_ME@db-host:5432/theater
# WeatherSniffer's own schema (its tables live here).
DATABASE_SCHEMA=weathersniffer

# --- Shared SSO auth ----------------------------------------------------------
# Set to the shared schema name ('shared') to ENABLE login via the family SSO.
# Leave EMPTY to run without a login gate (dev only).
AUTH_DB_SCHEMA=

# Per-app Flask secret — only for flash()/CSRF; need NOT match sibling apps.
SECRET_KEY=CHANGE_ME_openssl_rand_hex_32

# Set to 1 on HTTPS deployments (the session id is a bearer token).
SESSION_COOKIE_SECURE=
# Shared parent domain for cross-subdomain SSO (e.g. .example.com), else unset.
SESSION_COOKIE_DOMAIN=

# --- Web bind -------------------------------------------------------------------
WEB_HOST=0.0.0.0
WEB_PORT=7170

# --- External read API (/api/v1) --------------------------------------------------
# Optional key (X-API-Key header or ?api_key=). Unset = open on a trusted LAN.
API_KEY=

# --- Initial seeds (editable later in the Settings UI) -----------------------------
SYSLOG_ADDRESS=/dev/log
SYSLOG_FACILITY=local0
LOG_LEVEL=INFO
DEFAULT_POLL_SECONDS=60
# Blank = keep readings/action-log history forever.
DEFAULT_RETENTION_DAYS=
# Convenience default for Spot actions, e.g. http://spot-host:6100
SPOT_DEFAULT_BASE_URL=
